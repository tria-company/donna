{
  "$schema": "https://opencode.ai/config.json",
  // Default model: OpenRouter Auto Router — picks a capable (tool-supporting)
  // model per request. Fallback order: persisted UI selection -> agent.model
  // -> this -> provider default.
  "model": "openrouter/openrouter/auto",
  "permission": {
    "*": "allow",
    "task": "deny"
    // Donna fork: knowledge base (RAG) access is per-document × per-agent and
    // injected at runtime by apps/api knowledge/inject.ts as `kb_<agent>` MCP
    // servers + per-agent `kb_<agent>_search` permissions — nothing baked here.
  },
  "autoupdate": false,
  "disabled_providers": ["opencode", "anthropic", "kortix"],
  "default_agent": "general",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  // Donna fork: ./donna-system.md is layered AFTER kortix-system.md so its
  // identity (Donna), language (forced PT-BR), and deployment posture
  // (internal-tool, no billing) override the defaults without touching
  // the upstream technical context — kortix-system.md stays mergeable.
  "instructions": ["./kortix-system.md", "./donna-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "env": ["ANTHROPIC_API_KEY"],
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "id": "claude-sonnet-4-6",
          "family": "anthropic"
        }
      }
    },
    "kortix-yolo": {
      // Donna fork: agent LLM routes through OpenRouter (OpenAI-compatible).
      // baseURL/apiKey come from env (KORTIX_YOLO_URL=https://openrouter.ai/api/v1,
      // KORTIX_YOLO_API_KEY=<OpenRouter key>) injected by sandbox-auth.ts.
      // Only tool-capable models are listed (the agent relies on tool-calling).
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["KORTIX_YOLO_API_KEY", "KORTIX_YOLO_URL"],
      "options": {
        "baseURL": "{env:KORTIX_YOLO_URL}",
        "apiKey": "{env:KORTIX_YOLO_API_KEY}"
      },
      "models": {
        "kortix-yolo/think": { "name": "Claude Sonnet 4.6", "id": "anthropic/claude-sonnet-4.6", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/fast": { "name": "Claude Haiku 4.5", "id": "anthropic/claude-haiku-4.5", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/opus": { "name": "Claude Opus 4.8", "id": "anthropic/claude-opus-4.8", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/gpt4o": { "name": "GPT-4o", "id": "openai/gpt-4o", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/gemini": { "name": "Gemini 3 Flash", "id": "google/gemini-3-flash-preview", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/grok": { "name": "Grok 4.20", "id": "x-ai/grok-4.20", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/glm": { "name": "GLM 5.1", "id": "z-ai/glm-5.1", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/kimi": { "name": "Kimi K2.6", "id": "moonshotai/kimi-k2.6", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/minimax": { "name": "MiniMax M3", "id": "minimax/minimax-m3", "family": "kortix-yolo", "tool_call": true },
        "kortix-yolo/deepseek": { "name": "DeepSeek V4 Pro", "id": "deepseek/deepseek-v4-pro", "family": "kortix-yolo", "tool_call": true }
      }
    }
    // "kortix": {
    //   "npm": "@ai-sdk/openai-compatible",
    //   "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
    //   "options": {
    //     "baseURL": "{env:KORTIX_API_URL}/v1/router",
    //     "apiKey": "{env:KORTIX_TOKEN}"
    //   },
    //   "models": {
    //     "minimax-m27": {
    //       "name": "MiniMax M2.7",
    //       "id": "minimax/minimax-m2.7",
    //       "family": "kortix",
    //       "cost": { "input": 0.30, "output": 1.20 },
    //       "limit": { "context": 204800, "output": 131072 }
    //     },
    //     "glm-turbo": {
    //       "name": "GLM-5 Turbo",
    //       "id": "z-ai/glm-5-turbo",
    //       "family": "kortix",
    //       "cost": { "input": 1.20, "output": 4.00 },
    //       "limit": { "context": 202752, "output": 131072 }
    //     },
    //     "kimi": {
    //       "name": "Kimi K2.5",
    //       "id": "moonshotai/kimi-k2.5",
    //       "family": "kortix",
    //       "cost": { "input": 0.45, "output": 2.20 },
    //       "limit": { "context": 262144, "output": 65535 }
    //     },
    //     "minimax": {
    //       "name": "MiniMax M2.5",
    //       "id": "minimax/minimax-m2.5",
    //       "family": "kortix",
    //       "cost": { "input": 0.20, "output": 1.17 },
    //       "limit": { "context": 196608, "output": 65536 }
    //     }
    //   }
    // }
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
    // Donna fork: knowledge-base MCP servers (kb_<agent>) are injected per-account
    // at runtime by apps/api knowledge/inject.ts — see permission note above.
  }
}
