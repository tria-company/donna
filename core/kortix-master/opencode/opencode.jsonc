{
  "$schema": "https://opencode.ai/config.json",
  // Default model: Claude Sonnet 4.6 via a assinatura Claude Pro/Max (OAuth),
  // roteada pelo backend (provider `anthropic` aponta para {KORTIX_API_URL}/v1/router).
  // Donna fork: sem OpenRouter, sem API key — a credencial fica central no backend.
  // Fallback order: persisted UI selection -> agent.model -> this -> provider default.
  "model": "anthropic/claude-sonnet-4-6",
  "permission": {
    "*": "allow",
    "task": "deny"
    // Donna fork: knowledge base (RAG) access is per-document × per-agent and
    // injected at runtime by apps/api knowledge/inject.ts as `kb_<agent>` MCP
    // servers + per-agent `kb_<agent>_search` permissions — nothing baked here.
  },
  "autoupdate": false,
  // Donna fork: provider `anthropic` ligado (assinatura Claude Pro/Max via backend).
  // OpenRouter removido: `kortix-yolo` deletado E o built-in `openrouter` desabilitado
  // (o opencode auto-ativa ele se houver OPENROUTER key no env). Só Claude.
  "disabled_providers": ["opencode", "kortix", "openrouter"],
  "default_agent": "general",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  // Donna fork: ./donna-system.md is layered AFTER kortix-system.md so its
  // identity (Donna), language (forced PT-BR), and deployment posture
  // (internal-tool, no billing) override the defaults without touching
  // the upstream technical context — kortix-system.md stays mergeable.
  "instructions": ["./kortix-system.md", "./donna-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    "anthropic": {
      // Donna fork: NÃO fala direto com api.anthropic.com. Aponta para o router do
      // backend ({KORTIX_API_URL}/v1/router → POST /messages), que segura a credencial
      // OAuth da assinatura Claude Pro/Max (central, refresh central) e injeta o bearer
      // + headers do Claude Code. O sandbox autentica no backend com KORTIX_TOKEN e
      // nunca vê o refresh token. cache_control é injetado pelo @ai-sdk/anthropic e
      // preservado pelo router.
      "npm": "@ai-sdk/anthropic",
      "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}",
        // @ai-sdk/anthropic manda o apiKey como `x-api-key`, mas o router do backend
        // (apiKeyAuth) exige `Authorization: Bearer`. Mandamos os dois.
        "headers": { "Authorization": "Bearer {env:KORTIX_TOKEN}" }
      },
      "models": {
        "claude-sonnet-4-6": { "name": "Claude Sonnet 4.6", "id": "claude-sonnet-4-6", "family": "anthropic", "tool_call": true },
        "claude-opus-4-8": { "name": "Claude Opus 4.8", "id": "claude-opus-4-8", "family": "anthropic", "tool_call": true },
        "claude-haiku-4-5": { "name": "Claude Haiku 4.5", "id": "claude-haiku-4-5", "family": "anthropic", "tool_call": true }
      }
    }
    // "kortix": {
    //   "npm": "@ai-sdk/openai-compatible",
    //   "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
    //   "options": {
    //     "baseURL": "{env:KORTIX_API_URL}/v1/router",
    //     "apiKey": "{env:KORTIX_TOKEN}"
    //   },
    //   "models": {
    //     "minimax-m27": {
    //       "name": "MiniMax M2.7",
    //       "id": "minimax/minimax-m2.7",
    //       "family": "kortix",
    //       "cost": { "input": 0.30, "output": 1.20 },
    //       "limit": { "context": 204800, "output": 131072 }
    //     },
    //     "glm-turbo": {
    //       "name": "GLM-5 Turbo",
    //       "id": "z-ai/glm-5-turbo",
    //       "family": "kortix",
    //       "cost": { "input": 1.20, "output": 4.00 },
    //       "limit": { "context": 202752, "output": 131072 }
    //     },
    //     "kimi": {
    //       "name": "Kimi K2.5",
    //       "id": "moonshotai/kimi-k2.5",
    //       "family": "kortix",
    //       "cost": { "input": 0.45, "output": 2.20 },
    //       "limit": { "context": 262144, "output": 65535 }
    //     },
    //     "minimax": {
    //       "name": "MiniMax M2.5",
    //       "id": "minimax/minimax-m2.5",
    //       "family": "kortix",
    //       "cost": { "input": 0.20, "output": 1.17 },
    //       "limit": { "context": 196608, "output": 65536 }
    //     }
    //   }
    // }
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      // Donna fork: desligado por padrão p/ não injetar o catálogo de tools em
      // todo turno. Valor (docs de libs) já coberto por web_search/scrape_webpage.
      // Flip p/ true quando precisar de lookup de documentação de biblioteca.
      "enabled": false
    }
    // Donna fork: knowledge-base MCP servers (kb_<agent>) are injected per-account
    // at runtime by apps/api knowledge/inject.ts — see permission note above.
  }
}
