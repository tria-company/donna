# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Backend (kortix-api) — VPS HostHatch                                      ║
# ║  Copie para `.env` e preencha. O servidor valida no boot e NÃO sobe        ║
# ║  se faltar [REQUIRED]. Lista completa: apps/api/.env.example               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Core ───────────────────────────────────────────────────────────────────
PORT=8008
ENV_MODE=local                 # 'local' = self-hosted (sem billing Stripe). 'cloud' exige Stripe.

# ─── Banco / Supabase (Cloud) [REQUIRED] ──────────────────────────────────────
DATABASE_URL=                  # postgres da sua Cloud Supabase (Connection string, porta 6543 pooler)
SUPABASE_URL=                  # https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # service_role (dashboard Supabase → API)

# ─── Segurança [REQUIRED] ─────────────────────────────────────────────────────
API_KEY_SECRET=                # 64 chars hex — gere: openssl rand -hex 32
TUNNEL_SIGNING_SECRET=         # 64 chars hex — gere: openssl rand -hex 32
# INTERNAL_SERVICE_KEY=        # auto-gerado no 1º boot; NÃO apague depois de setado

# ─── Sandbox = Daytona (nuvem) ────────────────────────────────────────────────
ALLOWED_SANDBOX_PROVIDERS=daytona
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=

# ─── LLM (OpenRouter — rota da Donna) ─────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=                # usado p/ embeddings da base de conhecimento (RAG)

# ─── LIGAÇÃO COM O FRONTEND (Vercel) ⚠️ o passo que conecta os dois ───────────
# Domínio(s) do front na Vercel, separados por vírgula. Sem isto → CORS bloqueia.
CORS_ALLOWED_ORIGINS=https://SEU-FRONT.vercel.app
FRONTEND_URL=https://SEU-FRONT.vercel.app

# ─── Integrações (opcional — preencha se usar) ────────────────────────────────
# INTEGRATION_AUTH_PROVIDER=pipedream
# PIPEDREAM_CLIENT_ID=
# PIPEDREAM_CLIENT_SECRET=
# PIPEDREAM_PROJECT_ID=
# CRON_TICK_SECRET=
